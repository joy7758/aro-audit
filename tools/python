#!/bin/bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [ -x "$ROOT_DIR/.venv/bin/python" ]; then
  exec "$ROOT_DIR/.venv/bin/python" "$@"
elif command -v python >/dev/null 2>&1; then
  exec python "$@"
elif command -v python3 >/dev/null 2>&1; then
  exec python3 "$@"
else
  echo "NO_PYTHON_FOUND"
  exit 127
fi
